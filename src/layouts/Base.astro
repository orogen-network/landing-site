---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

export interface Props {
  title: string;
  description: string;
  /** Path component for canonical/og:url, e.g. "/operators". Defaults to "/". */
  path?: string;
  /** Optional override for og:image. Defaults to /og-image.png. */
  ogImage?: string;
}

const {
  title,
  description,
  path = "/",
  ogImage = "/og-image.png",
} = Astro.props;

const siteUrl = "https://orogen.network";
const canonical = `${siteUrl}${path === "/" ? "" : path.replace(/\/$/, "")}`;
const fullOg = ogImage.startsWith("http") ? ogImage : `${siteUrl}${ogImage}`;
const fullTitle =
  title === "Orogen"
    ? "Orogen: open-model inference you can audit"
    : `${title} · Orogen`;

// Structured data (homepage only) so search engines recognize Orogen as an
// entity and link the brand to its social accounts.
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "Orogen",
    url: siteUrl,
    logo: `${siteUrl}/orogen-logo-512.png`,
    description:
      "Orogen is a decentralized network for verifiable LLM inference: an OpenAI-compatible gateway routed to attested GPU operators, with validator replay and burn-and-mint settlement on a Substrate-based chain.",
    sameAs: [
      "https://x.com/Orogen_Network",
      "https://github.com/orogen-network",
      "https://discord.gg/orogen",
      "https://t.me/orogen_network",
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "Orogen",
    url: siteUrl,
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!--
      Content-Security-Policy meta fallback. Mirrors public/_headers so the
      policy ships even if edge config drifts. NOTE: `frame-ancestors`,
      `report-uri`, and `sandbox` cannot be set from a meta tag; the
      hosting-tier `_headers` file is authoritative for those.
    -->
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'; connect-src 'self'; base-uri 'self'; form-action 'self'; object-src 'none'"
    />
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Orogen" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={fullOg} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Orogen: open-model inference you can audit" />

    <!-- Twitter card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@Orogen_Network" />
    <meta name="twitter:creator" content="@Orogen_Network" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullOg} />
    <meta name="twitter:image:alt" content="Orogen: open-model inference you can audit" />

    <meta name="theme-color" content="#0b0d10" />

    {
      path === "/" && (
        <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
      )
    }
  </head>
  <body class="flex min-h-screen flex-col">
    <Nav currentPath={path} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
