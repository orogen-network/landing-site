---
export interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;

const navItems: { label: string; href: string }[] = [
  { label: "How it works", href: "/how-it-works" },
  { label: "Operators", href: "/operators" },
  { label: "Customers", href: "/customers" },
  { label: "Validators", href: "/validators" },
  { label: "Tokenomics", href: "/tokenomics" },
  { label: "Roadmap", href: "/roadmap" },
  { label: "Downloads", href: "/downloads" },
  { label: "FAQ", href: "/faq" },
];

const isActive = (href: string) =>
  href === "/"
    ? currentPath === "/"
    : currentPath === href || currentPath.startsWith(`${href}/`);
---

<header class="sticky top-0 z-40 border-b border-crust-800/80 bg-crust-950/85 backdrop-blur">
  <div class="container-page flex h-16 items-center justify-between gap-6">
    <a href="/" class="flex items-center gap-2 text-crust-100 no-underline">
      <svg
        viewBox="0 0 64 64"
        class="h-8 w-8"
        role="img"
        aria-label="Orogen mark"
      >
        <path
          d="M6 50 L22 22 L30 34 L40 14 L58 50 Z"
          fill="none"
          stroke="#f59e0b"
          stroke-width="3"
          stroke-linejoin="miter"
        />
        <line x1="6" y1="50" x2="58" y2="50" stroke="#f59e0b" stroke-width="3" />
        <path
          d="M22 22 L30 34 L40 14"
          fill="none"
          stroke="#34d399"
          stroke-width="1.6"
          stroke-linejoin="miter"
        />
      </svg>
      <span class="text-lg font-semibold tracking-tight">Orogen</span>
    </a>

    <nav class="hidden flex-1 items-center justify-center gap-1 lg:flex" aria-label="Primary">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class={`rounded px-3 py-1.5 text-sm transition-colors no-underline ${
              isActive(item.href)
                ? "bg-crust-800 text-crust-100"
                : "text-crust-300 hover:bg-crust-800/60 hover:text-crust-100"
            }`}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <a
        href="https://docs.orogen.network"
        class="hidden text-sm text-crust-300 no-underline hover:text-crust-100 sm:inline-block"
        rel="noopener noreferrer"
      >
        Docs
      </a>
      <a
        href="https://gateway.orogen.network"
        rel="noopener noreferrer"
        class="rounded-md border border-magma-500/60 bg-magma-500/10 px-3 py-1.5 text-sm font-medium text-magma-300 no-underline hover:bg-magma-500/20"
      >
        Launch app
      </a>
    </div>
  </div>

  <!-- compact mobile nav -->
  <nav class="container-page lg:hidden" aria-label="Primary (mobile)">
    <ul class="flex flex-wrap gap-x-4 gap-y-1 pb-3 text-sm">
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class={`no-underline ${
                isActive(item.href)
                  ? "text-magma-300"
                  : "text-crust-300 hover:text-crust-100"
              }`}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
