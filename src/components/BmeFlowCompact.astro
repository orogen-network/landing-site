---
// BmeFlowCompact.astro — compact vertical flow of the burn-and-mint loop.
// Five steps, then a 4-way emission split. Replaces the ASCII-art block on
// the index page. Pure HTML + a small SVG chevron between steps; scales
// down to a single column on mobile without breaking.

interface Step {
  kind: "in" | "burn" | "exec" | "verify" | "mint";
  eyebrow: string;
  title: string;
  detail: string;
}

const steps: Step[] = [
  {
    kind: "in",
    eyebrow: "01 · top-up",
    title: "Customer pays USDC / USD / ETH / BTC",
    detail: "Gateway-recorded, oracle-quoted at top-up time.",
  },
  {
    kind: "burn",
    eyebrow: "02 · burn",
    title: "Gateway burns OROG at oracle spot",
    detail:
      "Pallet-bme retires OROG and mints non-transferable CUC — USD-pegged, 30-day expiry. No skip-the-token backdoor.",
  },
  {
    kind: "exec",
    eyebrow: "03 · route + execute",
    title: "Operator runs vLLM / SGLang / TRT-LLM in TEE",
    detail:
      "Multi-objective router picks by tier + region + KV-warmness. Deterministic kernel, signed response receipt returned over the wire.",
  },
  {
    kind: "verify",
    eyebrow: "04 · verify",
    title: "Validators sample-replay 1–5% on-chain",
    detail:
      "Mismatch → opML challenge window. Bisection game narrows the divergent layer; dispute panel renders a slashing decision.",
  },
  {
    kind: "mint",
    eyebrow: "05 · settle",
    title: "pallet-bme mints fresh OROG at oracle spot",
    detail:
      "CUC consumed, OROG minted bounded by the year-N cap × rolling-burn envelope × 5% / yr ceiling, then split four ways.",
  },
];

const splits = [
  { pct: 75, label: "Operator", tone: "magma-strong" },
  { pct: 15, label: "Verification", tone: "crystal" },
  { pct: 5, label: "Treasury", tone: "magma-soft" },
  { pct: 5, label: "Governance", tone: "crust" },
];

const toneClasses: Record<string, string> = {
  "magma-strong": "bg-magma-500 text-crust-950",
  crystal: "bg-crystal-500 text-crust-950",
  "magma-soft": "bg-magma-400 text-crust-950",
  crust: "bg-crust-400 text-crust-950",
};

const kindAccent: Record<Step["kind"], string> = {
  in: "border-l-crystal-500",
  burn: "border-l-magma-500",
  exec: "border-l-magma-400",
  verify: "border-l-crystal-400",
  mint: "border-l-magma-500",
};
---

<figure
  class="surface-card-strong"
  aria-label="Burn-and-mint loop: customer pays, gateway burns OROG, operator executes in TEE, validators sample-replay, pallet-bme mints OROG split 75/15/5/5."
>
  <div class="flex items-baseline justify-between border-b border-crust-800 pb-3">
    <div>
      <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-crust-500">
        Burn-and-mint loop · pallet-bme
      </p>
      <h3 class="mt-1 text-lg font-semibold tracking-tight text-crust-100">
        One job, one closed loop
      </h3>
    </div>
    <p class="hidden font-mono text-[10px] uppercase tracking-[0.18em] text-crust-500 sm:block">
      USD in · OROG burned · OROG minted · USD out
    </p>
  </div>

  <ol class="mt-6 space-y-0">
    {
      steps.map((s, i) => (
        <li class="relative">
          <div
            class={`rounded-md border border-crust-800 border-l-2 bg-crust-900/60 px-4 py-3 ${kindAccent[s.kind]}`}
          >
            <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-crust-500">
              {s.eyebrow}
            </p>
            <p class="mt-1 text-sm font-semibold text-crust-100">{s.title}</p>
            <p class="mt-1 text-xs leading-relaxed text-crust-400">
              {s.detail}
            </p>
          </div>
          {i < steps.length - 1 && (
            <div
              class="flex justify-center py-2 text-crust-600"
              aria-hidden="true"
            >
              <svg
                viewBox="0 0 16 16"
                class="h-4 w-4"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M8 3v9m0 0l-4-4m4 4l4-4" />
              </svg>
            </div>
          )}
        </li>
      ))
    }
  </ol>

  <!-- 4-way split row -->
  <div class="mt-6">
    <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-crust-500">
      Emission split · per finalised job
    </p>
    <div
      class="mt-3 flex h-10 w-full overflow-hidden rounded-sm ring-1 ring-crust-800"
      role="img"
      aria-label="Stacked emission bar: 75% operator, 15% verification, 5% treasury, 5% governance"
    >
      {
        splits.map((s, i) => (
          <div
            style={`width: ${s.pct}%`}
            class={`flex items-center justify-center font-mono text-xs font-semibold tabular-nums ${toneClasses[s.tone]} ${
              i > 0 ? "border-l border-crust-950/40" : ""
            }`}
          >
            {s.pct}%
          </div>
        ))
      }
    </div>
    <div
      class="mt-2 grid grid-cols-4 gap-2 font-mono text-[10px] uppercase tracking-[0.16em] text-crust-400"
    >
      {
        splits.map((s) => (
          <p class="truncate">{s.label}</p>
        ))
      }
    </div>
  </div>
</figure>
