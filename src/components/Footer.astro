---
const year = new Date().getFullYear();

const socials: { label: string; href: string; icon: string }[] = [
  {
    label: "GitHub",
    href: "https://github.com/orogen-network",
    icon: "github",
  },
  {
    label: "X (Twitter)",
    href: "https://x.com/orogen_network",
    icon: "twitter",
  },
  { label: "Discord", href: "https://discord.gg/orogen", icon: "discord" },
  { label: "Telegram", href: "https://t.me/orogen_network", icon: "telegram" },
];
---

<footer class="mt-24 border-t border-crust-800/80 bg-crust-950">
  <div class="container-page py-12">
    <div class="grid gap-8 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5">
      <div>
        <div class="flex items-center gap-2">
          <svg viewBox="0 0 64 64" class="h-7 w-7" role="img" aria-label="Orogen">
            <path
              d="M6 50 L22 22 L30 34 L40 14 L58 50 Z"
              fill="none"
              stroke="#f59e0b"
              stroke-width="3"
              stroke-linejoin="miter"
            />
            <line x1="6" y1="50" x2="58" y2="50" stroke="#f59e0b" stroke-width="3" />
          </svg>
          <span class="text-base font-semibold tracking-tight text-crust-100">Orogen</span>
        </div>
        <p class="mt-3 text-sm leading-relaxed text-crust-400">
          Open-model LLM inference you can audit. A signed receipt on every
          response, validator replay on identical hardware, and burn-and-mint
          settlement that pays operators in dollar terms for verified work.
        </p>
      </div>

      <div>
        <div class="heading-eyebrow text-xs">Product</div>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a class="text-crust-300 no-underline hover:text-crust-100" href="/how-it-works">How it works</a></li>
          <li><a class="text-crust-300 no-underline hover:text-crust-100" href="/customers">For customers</a></li>
          <li><a class="text-crust-300 no-underline hover:text-crust-100" href="/operators">For operators</a></li>
          <li><a class="text-crust-300 no-underline hover:text-crust-100" href="/validators">For validators</a></li>
          <li><a class="text-crust-300 no-underline hover:text-crust-100" href="/downloads">Downloads</a></li>
        </ul>
      </div>

      <div>
        <div class="heading-eyebrow text-xs">Resources</div>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a class="text-crust-300 no-underline hover:text-crust-100" href="https://docs.orogen.network" rel="noopener noreferrer">Documentation</a></li>
          <li><a class="text-crust-300 no-underline hover:text-crust-100" href="/tokenomics">Tokenomics</a></li>
          <li><a class="text-crust-300 no-underline hover:text-crust-100" href="/roadmap">Roadmap</a></li>
          <li><a class="text-crust-300 no-underline hover:text-crust-100" href="/faq">FAQ</a></li>
          <li><a class="text-crust-300 no-underline hover:text-crust-100" href="mailto:hello@orogen.network">Contact</a></li>
        </ul>
      </div>

      <div>
        <div class="heading-eyebrow text-xs">Network surfaces</div>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a class="text-crust-300 no-underline hover:text-crust-100" href="https://status.orogen.network" rel="noopener noreferrer">Status</a></li>
          <li><a class="text-crust-300 no-underline hover:text-crust-100" href="https://explorer.orogen.network" rel="noopener noreferrer">Chain explorer</a></li>
          <li><a class="text-crust-300 no-underline hover:text-crust-100" href="https://attestation.orogen.network" rel="noopener noreferrer">Receipt verifier</a></li>
          <li><a class="text-crust-300 no-underline hover:text-crust-100" href="/downloads">Downloads</a></li>
        </ul>
      </div>

      <div>
        <div class="heading-eyebrow text-xs">Community</div>
        <ul class="mt-3 flex flex-wrap gap-3">
          {
            socials.map((s) => (
              <li>
                <a
                  href={s.href}
                  rel="noopener noreferrer"
                  aria-label={s.label}
                  class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-crust-700/70 bg-crust-900 text-crust-300 no-underline hover:border-magma-500/60 hover:text-magma-300"
                >
                  {s.icon === "github" && (
                    <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
                      <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-2c-3.2.7-3.87-1.37-3.87-1.37-.52-1.33-1.27-1.69-1.27-1.69-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.69 1.25 3.35.96.1-.74.4-1.25.72-1.54-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11.05 11.05 0 015.8 0c2.2-1.49 3.17-1.18 3.17-1.18.62 1.59.23 2.76.11 3.05.74.81 1.18 1.84 1.18 3.1 0 4.43-2.7 5.4-5.27 5.69.41.36.78 1.06.78 2.14v3.17c0 .31.21.68.8.56C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"/>
                    </svg>
                  )}
                  {s.icon === "twitter" && (
                    <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
                      <path d="M18.244 2H21l-6.523 7.456L22.5 22h-6.79l-4.74-6.211L5.5 22H2.74l6.978-7.973L1.5 2h6.93l4.29 5.71L18.244 2zm-2.387 18h1.55L7.27 4H5.62l10.237 16z"/>
                    </svg>
                  )}
                  {s.icon === "discord" && (
                    <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
                      <path d="M20.317 4.369A19.79 19.79 0 0016.558 3l-.198.359a14.6 14.6 0 014.05 1.378A18.74 18.74 0 0012 4c-1.6 0-3.18.18-4.41.737A14.6 14.6 0 0011.64 3.36L11.442 3a19.79 19.79 0 00-3.76 1.369C3.602 8.66 2.93 12.85 3.225 16.97A19.94 19.94 0 008.94 19.5l.733-1.205a13 13 0 01-2.07-1l.41-.323a13.4 13.4 0 0011.974 0l.41.323a13 13 0 01-2.07 1l.733 1.205a19.94 19.94 0 005.716-2.53c.452-4.713-.66-8.866-3.96-12.601zM9.5 14.5c-.83 0-1.5-.84-1.5-1.875S8.67 10.75 9.5 10.75s1.5.84 1.5 1.875S10.33 14.5 9.5 14.5zm5 0c-.83 0-1.5-.84-1.5-1.875s.67-1.875 1.5-1.875 1.5.84 1.5 1.875S15.33 14.5 14.5 14.5z"/>
                    </svg>
                  )}
                  {s.icon === "telegram" && (
                    <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
                      <path d="M9.04 15.5l-.36 4.4c.52 0 .74-.22 1.01-.49l2.42-2.3 5 3.66c.92.5 1.58.24 1.82-.85L22.9 4.6h.01c.27-1.36-.49-1.89-1.39-1.56L2.3 10.41c-1.32.5-1.3 1.23-.22 1.56l4.97 1.55 11.55-7.27c.54-.36 1.04-.16.63.2L9.04 15.5z"/>
                    </svg>
                  )}
                </a>
              </li>
            ))
          }
        </ul>
        <p class="mt-3 text-xs text-crust-500">
          Live on the Forge testnet. Mainnet pricing and capacity are on the
          <a class="text-crust-400 no-underline hover:text-crust-200" href="/roadmap">roadmap</a>.
        </p>
      </div>
    </div>

    <div class="mt-10 flex flex-col items-start justify-between gap-3 border-t border-crust-800 pt-6 text-xs text-crust-500 sm:flex-row sm:items-center">
      <div>
        © {year} Orogen contributors. Code released under Apache-2.0.
      </div>
      <div class="flex flex-wrap gap-x-4 gap-y-1">
        <a class="text-crust-400 no-underline hover:text-crust-200" href="/legal">Legal</a>
        <a class="text-crust-400 no-underline hover:text-crust-200" href="/faq">FAQ</a>
        <a class="text-crust-400 no-underline hover:text-crust-200" href="mailto:hello@orogen.network">hello@orogen.network</a>
      </div>
    </div>
  </div>
</footer>
