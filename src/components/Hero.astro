---
import CtaButton from "./CtaButton.astro";
---

<section class="relative overflow-hidden">
  <!-- Faint background grid: instrument-panel vibe, not decoration -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 opacity-[0.07]"
  >
    <svg
      class="h-full w-full"
      xmlns="http://www.w3.org/2000/svg"
      preserveAspectRatio="xMidYMid slice"
    >
      <defs>
        <pattern
          id="hero-grid"
          width="48"
          height="48"
          patternUnits="userSpaceOnUse"
        >
          <path
            d="M 48 0 L 0 0 0 48"
            fill="none"
            stroke="#f59e0b"
            stroke-width="0.5"
          />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#hero-grid)" />
    </svg>
  </div>

  <div class="container-page relative pb-16 pt-20 lg:pb-24 lg:pt-28">
    <div class="grid items-center gap-12 lg:grid-cols-[1.05fr_1fr] lg:gap-16">
      <!-- ===================== LEFT: COPY ===================== -->
      <div class="max-w-2xl">
        <p class="heading-eyebrow">
          <span
            class="mr-2 inline-block h-1.5 w-1.5 -translate-y-0.5 rounded-full bg-magma-500 align-middle"
          ></span>
          Open-model inference, verifiable
        </p>

        <h1
          class="mt-4 text-4xl font-semibold leading-[1.05] tracking-tight sm:text-5xl lg:text-6xl"
        >
          Open-model inference<br class="hidden sm:inline" />
          you can audit.
        </h1>

        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-crust-300">
          Point your OpenAI client at Orogen and your existing code runs
          unchanged, at roughly $0.40 per 1M output tokens for Llama-3.1-70B.
          Every response comes back with a signed receipt you can verify
          yourself, and validators re-run a sample of jobs on identical hardware
          to catch anyone cutting corners.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <CtaButton href="https://app.orogen.network/playground" variant="primary" size="lg" rel="noopener noreferrer">
            Open Playground
          </CtaButton>
          <CtaButton href="https://onboarding.orogen.network" variant="secondary" size="lg" rel="noopener noreferrer">
            Start mining
          </CtaButton>
          <CtaButton
            href="/how-it-works"
            variant="ghost"
            size="lg"
          >
            How it works
          </CtaButton>
        </div>

        <ul
          class="mt-10 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-crust-400"
        >
          <li class="flex items-center gap-2">
            <span
              class="inline-block h-1.5 w-1.5 rounded-full bg-magma-500"
            ></span>
            OpenAI-compatible HTTP + SSE
          </li>
          <li class="flex items-center gap-2">
            <span
              class="inline-block h-1.5 w-1.5 rounded-full bg-crystal-500"
            ></span>
            A signed receipt on every response
          </li>
          <li class="flex items-center gap-2">
            <span
              class="inline-block h-1.5 w-1.5 rounded-full bg-crust-400"
            ></span>
            Validator replay on identical hardware
          </li>
        </ul>
      </div>

      <!-- ===================== RIGHT: VERIFY LOOP ===================== -->
      <!--
        The verification loop in plain terms: you, the network, the chain.
        You send a request and get back an answer plus a signed receipt.
        The network replays a sample of jobs to catch faults. The chain
        keeps the commitment so a disputed result has a record to settle
        against. No insider layer labels.
      -->
      <figure
        class="relative isolate mx-auto w-full max-w-[560px] lg:max-w-none"
        aria-label="The verification loop: you send a request and receive an answer with a signed receipt; the network replays a sample of jobs on identical hardware; the chain stores each commitment as the record disputes settle against."
      >
        <!-- corner ticks: "this is an instrument plate" -->
        <div
          aria-hidden="true"
          class="pointer-events-none absolute inset-0 z-10"
        >
          <span class="absolute left-0 top-0 h-3 w-px bg-crust-700"></span>
          <span class="absolute left-0 top-0 h-px w-3 bg-crust-700"></span>
          <span class="absolute right-0 top-0 h-3 w-px bg-crust-700"></span>
          <span class="absolute right-0 top-0 h-px w-3 bg-crust-700"></span>
          <span class="absolute bottom-0 left-0 h-3 w-px bg-crust-700"></span>
          <span class="absolute bottom-0 left-0 h-px w-3 bg-crust-700"></span>
          <span class="absolute bottom-0 right-0 h-3 w-px bg-crust-700"></span>
          <span class="absolute bottom-0 right-0 h-px w-3 bg-crust-700"></span>
        </div>

        <!-- plate caption strip -->
        <figcaption
          class="flex items-center justify-between border border-crust-800 border-b-0 bg-crust-900/60 px-3 py-1.5 font-mono text-[10px] uppercase tracking-[0.18em] text-crust-500"
        >
          <span>the verification loop</span>
          <span class="text-crust-600">you · network · chain</span>
        </figcaption>

        <div
          class="rounded-b-sm border border-crust-800 bg-crust-950/60 p-4 backdrop-blur-sm"
        >
          <svg
            viewBox="0 0 640 520"
            class="block h-auto w-full"
            role="img"
            aria-hidden="true"
          >
            <defs>
              <radialGradient id="hero-glow" cx="0.5" cy="0.42" r="0.6">
                <stop offset="0%" stop-color="#f59e0b" stop-opacity="0.12" />
                <stop offset="60%" stop-color="#f59e0b" stop-opacity="0.03" />
                <stop offset="100%" stop-color="#0b0d10" stop-opacity="0" />
              </radialGradient>
              <marker
                id="hero-arrow"
                viewBox="0 0 10 10"
                refX="8"
                refY="5"
                markerWidth="7"
                markerHeight="7"
                orient="auto-start-reverse"
              >
                <path d="M 0 1 L 9 5 L 0 9 z" fill="#7c8597" />
              </marker>
              <marker
                id="hero-arrow-crystal"
                viewBox="0 0 10 10"
                refX="8"
                refY="5"
                markerWidth="7"
                markerHeight="7"
                orient="auto-start-reverse"
              >
                <path d="M 0 1 L 9 5 L 0 9 z" fill="#34d399" />
              </marker>
            </defs>

            <rect x="0" y="0" width="640" height="520" fill="url(#hero-glow)" />

            <!-- ── node: YOU ─────────────────────────────── -->
            <g>
              <rect
                x="44"
                y="206"
                width="150"
                height="108"
                rx="6"
                fill="#11141a"
                stroke="#36404f"
                stroke-width="1.25"
              ></rect>
              <text
                x="60"
                y="236"
                font-family="JetBrains Mono, ui-monospace, monospace"
                font-size="15"
                fill="#e9ebef"
              >You</text>
              <text
                x="60"
                y="262"
                font-family="JetBrains Mono, ui-monospace, monospace"
                font-size="10"
                fill="#7c8597"
              >your OpenAI client,</text>
              <text
                x="60"
                y="276"
                font-family="JetBrains Mono, ui-monospace, monospace"
                font-size="10"
                fill="#7c8597"
              >one base URL away</text>
              <text
                x="60"
                y="300"
                font-family="JetBrains Mono, ui-monospace, monospace"
                font-size="10"
                fill="#6ee7b7"
              >verify receipt locally</text>
            </g>

            <!-- ── node: THE NETWORK ─────────────────────── -->
            <g>
              <rect
                x="245"
                y="150"
                width="150"
                height="220"
                rx="6"
                fill="#11141a"
                stroke="#f59e0b"
                stroke-width="1.25"
                stroke-opacity="0.7"
              ></rect>
              <text
                x="262"
                y="180"
                font-family="JetBrains Mono, ui-monospace, monospace"
                font-size="15"
                fill="#fbbf24"
              >The network</text>
              <text
                x="262"
                y="206"
                font-family="JetBrains Mono, ui-monospace, monospace"
                font-size="10"
                fill="#7c8597"
              >attested GPU operators</text>
              <!-- replay loop glyph -->
              <path
                d="M 286 250 a 28 28 0 1 1 -8 20"
                fill="none"
                stroke="#34d399"
                stroke-width="1.5"
                marker-end="url(#hero-arrow-crystal)"
              ></path>
              <text
                x="320"
                y="262"
                font-family="JetBrains Mono, ui-monospace, monospace"
                font-size="10"
                fill="#6ee7b7"
              >validators</text>
              <text
                x="320"
                y="276"
                font-family="JetBrains Mono, ui-monospace, monospace"
                font-size="10"
                fill="#6ee7b7"
              >replay a</text>
              <text
                x="320"
                y="290"
                font-family="JetBrains Mono, ui-monospace, monospace"
                font-size="10"
                fill="#6ee7b7"
              >sample</text>
              <text
                x="262"
                y="344"
                font-family="JetBrains Mono, ui-monospace, monospace"
                font-size="10"
                fill="#7c8597"
              >identical hardware</text>
            </g>

            <!-- ── node: THE CHAIN ───────────────────────── -->
            <g>
              <rect
                x="446"
                y="206"
                width="150"
                height="108"
                rx="6"
                fill="#11141a"
                stroke="#36404f"
                stroke-width="1.25"
              ></rect>
              <text
                x="462"
                y="236"
                font-family="JetBrains Mono, ui-monospace, monospace"
                font-size="15"
                fill="#e9ebef"
              >The chain</text>
              <text
                x="462"
                y="262"
                font-family="JetBrains Mono, ui-monospace, monospace"
                font-size="10"
                fill="#7c8597"
              >stores each</text>
              <text
                x="462"
                y="276"
                font-family="JetBrains Mono, ui-monospace, monospace"
                font-size="10"
                fill="#7c8597"
              >commitment</text>
              <text
                x="462"
                y="300"
                font-family="JetBrains Mono, ui-monospace, monospace"
                font-size="10"
                fill="#7c8597"
              >disputes settle here</text>
            </g>

            <!-- ── flow: you -> network (request) ────────── -->
            <line
              x1="196"
              y1="238"
              x2="243"
              y2="200"
              stroke="#7c8597"
              stroke-width="1.25"
              marker-end="url(#hero-arrow)"
            ></line>
            <text
              x="206"
              y="206"
              font-family="JetBrains Mono, ui-monospace, monospace"
              font-size="10"
              fill="#a5acbb"
            >request</text>

            <!-- ── flow: network -> you (answer + receipt) ─ -->
            <line
              x1="243"
              y1="320"
              x2="196"
              y2="284"
              stroke="#34d399"
              stroke-width="1.25"
              marker-end="url(#hero-arrow-crystal)"
            ></line>
            <text
              x="150"
              y="338"
              font-family="JetBrains Mono, ui-monospace, monospace"
              font-size="10"
              fill="#6ee7b7"
            >answer + signed receipt</text>

            <!-- ── flow: network <-> chain (commitment) ──── -->
            <line
              x1="397"
              y1="260"
              x2="444"
              y2="260"
              stroke="#7c8597"
              stroke-width="1.25"
              marker-end="url(#hero-arrow)"
            ></line>
            <text
              x="404"
              y="250"
              font-family="JetBrains Mono, ui-monospace, monospace"
              font-size="10"
              fill="#a5acbb"
            >commitment</text>

            <!-- ── readout panel bottom ──────────────────── -->
            <g transform="translate(230, 430)">
              <rect
                x="0"
                y="0"
                width="180"
                height="34"
                rx="4"
                fill="#11141a"
                stroke="#252b38"
                stroke-width="1"
              ></rect>
              <text
                x="12"
                y="14"
                font-family="JetBrains Mono, ui-monospace, monospace"
                font-size="8"
                fill="#4f5b6e"
                letter-spacing="0.1em"
              >RECEIPT</text>
              <text
                x="12"
                y="27"
                font-family="JetBrains Mono, ui-monospace, monospace"
                font-size="10"
                fill="#cdd1da"
              >model · input · output · attestation</text>
              <circle cx="168" cy="22" r="3" fill="#34d399"></circle>
            </g>
          </svg>
        </div>
      </figure>
    </div>
  </div>

  <div class="divider-igneous"></div>
</section>
