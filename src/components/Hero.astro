---
import CtaButton from "./CtaButton.astro";
---

<section class="relative overflow-hidden">
  <!-- Faint background grid: instrument-panel vibe, not decoration -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 opacity-[0.07]"
  >
    <svg
      class="h-full w-full"
      xmlns="http://www.w3.org/2000/svg"
      preserveAspectRatio="xMidYMid slice"
    >
      <defs>
        <pattern
          id="hero-grid"
          width="48"
          height="48"
          patternUnits="userSpaceOnUse"
        >
          <path
            d="M 48 0 L 0 0 0 48"
            fill="none"
            stroke="#f59e0b"
            stroke-width="0.5"
          />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#hero-grid)" />
    </svg>
  </div>

  <div class="container-page relative pb-16 pt-20 lg:pb-24 lg:pt-28">
    <div class="grid items-center gap-12 lg:grid-cols-[1.05fr_1fr] lg:gap-16">
      <!-- ===================== LEFT: COPY ===================== -->
      <div class="max-w-2xl">
        <p class="heading-eyebrow">
          <span
            class="mr-2 inline-block h-1.5 w-1.5 -translate-y-0.5 rounded-full bg-magma-500 align-middle"
          ></span>
          Verifiable inference network
        </p>

        <h1
          class="mt-4 text-4xl font-semibold leading-[1.05] tracking-tight sm:text-5xl lg:text-6xl"
        >
          Verifiable LLM inference,<br class="hidden sm:inline" />
          anchored to physical work.
        </h1>

        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-crust-300">
          Orogen routes OpenAI-compatible inference to a vetted pool of GPU
          operators with TEE attestation, deterministic kernels, and validator
          replay sampling. Every job emits a signed receipt that customers, the
          network, and the chain can independently verify.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <CtaButton href="/downloads" variant="primary" size="lg">
            Download SDK
          </CtaButton>
          <CtaButton href="/how-it-works" variant="secondary" size="lg">
            How it works
          </CtaButton>
          <CtaButton
            href="https://docs.orogen.network"
            variant="ghost"
            size="lg"
            rel="noopener noreferrer"
          >
            Read the docs
          </CtaButton>
        </div>

        <ul
          class="mt-10 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-crust-400"
        >
          <li class="flex items-center gap-2">
            <span
              class="inline-block h-1.5 w-1.5 rounded-full bg-crystal-500"
            ></span>
            OpenAI-compatible HTTP + SSE
          </li>
          <li class="flex items-center gap-2">
            <span
              class="inline-block h-1.5 w-1.5 rounded-full bg-magma-500"
            ></span>
            TEE-attested H100 / H200 / B200
          </li>
          <li class="flex items-center gap-2">
            <span
              class="inline-block h-1.5 w-1.5 rounded-full bg-crust-400"
            ></span>
            Burn-and-mint settlement accounting
          </li>
        </ul>
      </div>

      <!-- ===================== RIGHT: SCHEMATIC ===================== -->
      <!--
        Geological cross-section. Two annotated facets:
          - outer ridge   →  "burn / mint" (magma)
          - inner ridge   →  "validator replay" (crystal)
        Surveyor-style leader lines + JetBrains Mono mini-labels.
        Hand-tuned for a 640×520 viewBox so guide lines land cleanly.
      -->
      <figure
        class="relative isolate mx-auto w-full max-w-[560px] lg:max-w-none"
        aria-label="Schematic: outer magma ridge marks the burn-and-mint loop; inner emerald ridge marks the validator replay layer."
      >
        <!-- corner ticks: "this is an instrument plate" -->
        <div
          aria-hidden="true"
          class="pointer-events-none absolute inset-0 z-10"
        >
          <span class="absolute left-0 top-0 h-3 w-px bg-crust-700"></span>
          <span class="absolute left-0 top-0 h-px w-3 bg-crust-700"></span>
          <span class="absolute right-0 top-0 h-3 w-px bg-crust-700"></span>
          <span class="absolute right-0 top-0 h-px w-3 bg-crust-700"></span>
          <span class="absolute bottom-0 left-0 h-3 w-px bg-crust-700"></span>
          <span class="absolute bottom-0 left-0 h-px w-3 bg-crust-700"></span>
          <span class="absolute bottom-0 right-0 h-3 w-px bg-crust-700"></span>
          <span class="absolute bottom-0 right-0 h-px w-3 bg-crust-700"></span>
        </div>

        <!-- plate caption strip -->
        <figcaption
          class="flex items-center justify-between border border-crust-800 border-b-0 bg-crust-900/60 px-3 py-1.5 font-mono text-[10px] uppercase tracking-[0.18em] text-crust-500"
        >
          <span>plate 01 · verification stack</span>
          <span class="text-crust-600">scale 1:n</span>
        </figcaption>

        <div
          class="rounded-b-sm border border-crust-800 bg-crust-950/60 p-4 backdrop-blur-sm"
        >
          <svg
            viewBox="0 0 640 520"
            class="block h-auto w-full"
            role="img"
            aria-hidden="true"
          >
            <defs>
              <!-- subtle radial glow behind the mountain -->
              <radialGradient id="hero-glow" cx="0.45" cy="0.7" r="0.55">
                <stop offset="0%" stop-color="#f59e0b" stop-opacity="0.18" />
                <stop offset="60%" stop-color="#f59e0b" stop-opacity="0.04" />
                <stop offset="100%" stop-color="#0b0d10" stop-opacity="0" />
              </radialGradient>
              <radialGradient id="hero-glow-inner" cx="0.5" cy="0.45" r="0.3">
                <stop offset="0%" stop-color="#34d399" stop-opacity="0.20" />
                <stop offset="100%" stop-color="#34d399" stop-opacity="0" />
              </radialGradient>
              <!-- arrowhead marker for leader lines -->
              <marker
                id="hero-tick"
                viewBox="0 0 10 10"
                refX="5"
                refY="5"
                markerWidth="5"
                markerHeight="5"
                orient="auto"
              >
                <circle cx="5" cy="5" r="2" fill="#7c8597" />
              </marker>
            </defs>

            <!-- atmospheric glow -->
            <rect x="0" y="0" width="640" height="520" fill="url(#hero-glow)" />
            <rect
              x="120"
              y="60"
              width="400"
              height="300"
              fill="url(#hero-glow-inner)"
            />

            <!-- ── strata gridlines ───────────────────────── -->
            <g stroke="#1a1f29" stroke-width="1">
              <line x1="40" y1="100" x2="600" y2="100" />
              <line x1="40" y1="160" x2="600" y2="160" />
              <line x1="40" y1="220" x2="600" y2="220" />
              <line x1="40" y1="280" x2="600" y2="280" />
              <line x1="40" y1="340" x2="600" y2="340" />
              <line x1="40" y1="400" x2="600" y2="400" />
            </g>

            <!-- left-edge depth ruler -->
            <g
              font-family="JetBrains Mono, ui-monospace, monospace"
              font-size="9"
              fill="#4f5b6e"
            >
              <text x="20" y="103" text-anchor="end">L8</text>
              <text x="20" y="163" text-anchor="end">L6</text>
              <text x="20" y="223" text-anchor="end">L4</text>
              <text x="20" y="283" text-anchor="end">L2</text>
              <text x="20" y="343" text-anchor="end">L1</text>
            </g>

            <!-- horizon baseline -->
            <line
              x1="40"
              y1="430"
              x2="600"
              y2="430"
              stroke="#36404f"
              stroke-width="1"
            />
            <line
              x1="40"
              y1="434"
              x2="600"
              y2="434"
              stroke="#36404f"
              stroke-width="0.5"
              stroke-dasharray="2 3"
            />

            <!-- ── outer mountain ridge (magma) — burn / mint ── -->
            <!-- five-point ridge as in brand mark, but big and centered -->
            <path
              d="M 80 430 L 220 200 L 300 320 L 400 100 L 560 430 Z"
              fill="none"
              stroke="#f59e0b"
              stroke-width="2.5"
              stroke-linejoin="miter"
            />

            <!-- inner emerald ridge (validator replay) — the two inner segments -->
            <path
              d="M 220 200 L 300 320 L 400 100"
              fill="none"
              stroke="#34d399"
              stroke-width="1.6"
              stroke-linejoin="miter"
            />

            <!-- small attestation dots along the outer ridge -->
            <g fill="#f59e0b">
              <circle cx="220" cy="200" r="3" />
              <circle cx="400" cy="100" r="3" />
            </g>
            <g fill="#34d399">
              <circle cx="300" cy="320" r="3" />
            </g>

            <!-- ── annotation A: outer ridge → burn / mint ── -->
            <!-- guide line: from mid outer-right ridge up-right to label -->
            <g stroke="#7c8597" stroke-width="0.75" fill="none">
              <line x1="480" y1="265" x2="560" y2="180" />
              <line
                x1="560"
                y1="180"
                x2="612"
                y2="180"
                marker-start="url(#hero-tick)"
              />
            </g>
            <g
              font-family="JetBrains Mono, ui-monospace, monospace"
              font-size="10"
              fill="#fbbf24"
            >
              <text x="612" y="172" text-anchor="end">BURN · MINT</text>
              <text x="612" y="186" text-anchor="end" fill="#7c8597">
                outer ridge — pallet-bme
              </text>
              <text x="612" y="200" text-anchor="end" fill="#4f5b6e">
                75 / 15 / 5 / 5
              </text>
            </g>

            <!-- ── annotation B: inner ridge → validator replay ── -->
            <g stroke="#7c8597" stroke-width="0.75" fill="none">
              <line x1="300" y1="320" x2="180" y2="380" />
              <line
                x1="180"
                y1="380"
                x2="32"
                y2="380"
                marker-start="url(#hero-tick)"
              />
            </g>
            <g
              font-family="JetBrains Mono, ui-monospace, monospace"
              font-size="10"
              fill="#6ee7b7"
            >
              <text x="32" y="372">VALIDATOR REPLAY</text>
              <text x="32" y="386" fill="#7c8597">inner ridge — 1–5% sample</text>
              <text x="32" y="400" fill="#4f5b6e">Yuma consensus · L4</text>
            </g>

            <!-- ── annotation C: peak → physical work anchor ── -->
            <g stroke="#7c8597" stroke-width="0.75" fill="none" stroke-dasharray="2 2">
              <line x1="400" y1="100" x2="490" y2="60" />
            </g>
            <g
              font-family="JetBrains Mono, ui-monospace, monospace"
              font-size="9"
              fill="#a5acbb"
            >
              <text x="498" y="58">peak: signed receipt</text>
              <text x="498" y="70" fill="#4f5b6e">
                (model · adapter · prompt · output)
              </text>
            </g>

            <!-- ── baseline labels ─────────────────────────── -->
            <g
              font-family="JetBrains Mono, ui-monospace, monospace"
              font-size="9"
              fill="#4f5b6e"
            >
              <text x="40" y="448">customer USDC</text>
              <text x="320" y="448" text-anchor="middle">gateway</text>
              <text x="600" y="448" text-anchor="end">operator payout</text>
            </g>

            <!-- ── readout panel bottom-right ─────────────── -->
            <g transform="translate(420, 470)">
              <rect
                x="0"
                y="0"
                width="180"
                height="34"
                fill="#11141a"
                stroke="#252b38"
                stroke-width="1"
              />
              <text
                x="10"
                y="14"
                font-family="JetBrains Mono, ui-monospace, monospace"
                font-size="8"
                fill="#4f5b6e"
                letter-spacing="0.1em"
              >
                LATEST · DEMO READOUT
              </text>
              <text
                x="10"
                y="27"
                font-family="JetBrains Mono, ui-monospace, monospace"
                font-size="10"
                fill="#cdd1da"
              >
                receipt verified · L1–L8 ok
              </text>
              <circle cx="168" cy="22" r="3" fill="#34d399" />
            </g>
          </svg>
        </div>
      </figure>
    </div>
  </div>

  <div class="divider-igneous"></div>
</section>
