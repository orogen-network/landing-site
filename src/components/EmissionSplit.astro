---
// EmissionSplit.astro — visual rendering of the per-job emission split.
// Stacked horizontal bar: 75% operator / 15% verification / 5% treasury / 5% governance.
// Reads like a ledger row, not a marketing chart. JetBrains Mono percentages,
// generous tracking on labels, a baseline tick rule for "measurement, not decoration".

const segments = [
  {
    pct: 75,
    label: "Operator",
    detail: "Provider compute, the product",
    barClass: "bg-magma-500",
    dotClass: "bg-magma-500",
    textClass: "text-crust-950",
  },
  {
    pct: 15,
    label: "Verification",
    detail: "Validators · opML watchers · zkML provers",
    barClass: "bg-crystal-500",
    dotClass: "bg-crystal-500",
    textClass: "text-crust-950",
  },
  {
    pct: 5,
    label: "Treasury",
    detail: "Audits, security response, integrations",
    barClass: "bg-magma-400",
    dotClass: "bg-magma-400",
    textClass: "text-crust-950",
  },
  {
    pct: 5,
    label: "Governance",
    detail: "Slashing arbitration, parameter review",
    barClass: "bg-crust-400",
    dotClass: "bg-crust-400",
    textClass: "text-crust-950",
  },
];
---

<figure
  class="surface-card-strong"
  aria-label="Per-job emission split: 75% operator, 15% verification, 5% treasury, 5% governance"
>
  <!-- plate header -->
  <div class="flex items-baseline justify-between border-b border-crust-800 pb-3">
    <div>
      <p
        class="font-mono text-[10px] uppercase tracking-[0.22em] text-crust-500"
      >
        Per-job emission · pallet-bme
      </p>
      <h3 class="mt-1 text-lg font-semibold tracking-tight text-crust-100">
        75 / 15 / 5 / 5 split
      </h3>
    </div>
    <p class="font-mono text-xs tabular-nums text-crust-500">
      sum = 100.0&nbsp;%
    </p>
  </div>

  <!-- segment titles row -->
  <div class="mt-6 flex w-full text-xs">
    {
      segments.map((s) => (
        <div style={`width: ${s.pct}%`} class="pr-2 last:pr-0">
          <p class="truncate font-mono text-[10px] uppercase tracking-[0.16em] text-crust-400">
            {s.label}
          </p>
        </div>
      ))
    }
  </div>

  <!-- the bar -->
  <div
    class="mt-2 flex h-12 w-full overflow-hidden rounded-sm ring-1 ring-crust-800"
    role="img"
    aria-label="Stacked emission bar"
  >
    {
      segments.map((s, i) => (
        <div
          style={`width: ${s.pct}%`}
          class={`relative flex items-center justify-center ${s.barClass} ${
            i > 0 ? "border-l border-crust-950/40" : ""
          }`}
        >
          <span
            class={`font-mono text-sm font-semibold tabular-nums ${s.textClass}`}
          >
            {s.pct}%
          </span>
        </div>
      ))
    }
  </div>

  <!-- tick rule beneath the bar -->
  <svg
    viewBox="0 0 100 6"
    preserveAspectRatio="none"
    class="mt-1 block h-1.5 w-full"
    aria-hidden="true"
  >
    <line x1="0" y1="0" x2="0" y2="6" stroke="#36404f" stroke-width="0.6" />
    <line x1="25" y1="0" x2="25" y2="3" stroke="#252b38" stroke-width="0.4" />
    <line x1="50" y1="0" x2="50" y2="3" stroke="#252b38" stroke-width="0.4" />
    <line x1="75" y1="0" x2="75" y2="6" stroke="#36404f" stroke-width="0.6" />
    <line x1="90" y1="0" x2="90" y2="3" stroke="#252b38" stroke-width="0.4" />
    <line x1="95" y1="0" x2="95" y2="3" stroke="#252b38" stroke-width="0.4" />
    <line x1="100" y1="0" x2="100" y2="6" stroke="#36404f" stroke-width="0.6" />
  </svg>
  <div
    class="mt-1 flex justify-between font-mono text-[10px] tabular-nums text-crust-600"
  >
    <span>0</span>
    <span class="opacity-60">25</span>
    <span class="opacity-60">50</span>
    <span>75</span>
    <span class="opacity-60">95</span>
    <span>100</span>
  </div>

  <!-- legend / detail -->
  <dl class="mt-8 grid grid-cols-1 gap-x-6 gap-y-4 sm:grid-cols-2">
    {
      segments.map((s) => (
        <div class="flex items-start gap-3">
          <span
            class={`mt-1.5 inline-block h-2.5 w-2.5 shrink-0 rounded-sm ${s.dotClass}`}
            aria-hidden="true"
          />
          <div class="min-w-0">
            <dt class="flex items-baseline gap-2">
              <span class="text-sm font-medium text-crust-100">{s.label}</span>
              <span class="font-mono text-xs tabular-nums text-magma-300">
                {s.pct}%
              </span>
            </dt>
            <dd class="mt-0.5 text-xs leading-relaxed text-crust-400">
              {s.detail}
            </dd>
          </div>
        </div>
      ))
    }
  </dl>

  <p class="mt-6 border-t border-crust-800 pt-4 text-xs leading-relaxed text-crust-500">
    Split is at-launch parameter; constitutionally bounded — operator share
    cannot fall below 60% without supermajority governance and a 60-day
    timelock. No subnet-owner slice. No staker-for-yield slice. Every
    recipient is doing work.
  </p>
</figure>
