---
// BmeEnvelope.astro — small SVG chart of the per-epoch mint envelope.
//
//   mint_rate = max(  floor_0.5%,
//                     min( ceiling_5%,
//                          year_N_bootstrap_cap,
//                          rolling_180d_burn × elasticity ) )
//
// Bootstrap cap: 8% at TGE, linearly to 4% at month 24, then lifted.
// Burn × elasticity: noisy ramp, sometimes piercing the ceiling, sometimes
// dropping toward the floor in a demand trough.
// Hand-tuned data points so the envelope reads as plausible, not random.
// Chart in SVG viewBox 800×360. Plot area inset for axis labels.

// ----- chart geometry -----
const W = 800;
const H = 360;
const PAD_L = 64;
const PAD_R = 28;
const PAD_T = 30;
const PAD_B = 56;

const plotW = W - PAD_L - PAD_R; // 708
const plotH = H - PAD_T - PAD_B; // 274

// X domain: months 0..36
// Y domain: 0..10 (% of supply per year)
const xMin = 0;
const xMax = 36;
const yMin = 0;
const yMax = 10;

const xScale = (x: number) =>
  PAD_L + ((x - xMin) / (xMax - xMin)) * plotW;
const yScale = (y: number) =>
  PAD_T + plotH - ((y - yMin) / (yMax - yMin)) * plotH;

// ----- envelope bands -----
const CEIL = 5.0; // 5% / yr hard ceiling
const FLOOR = 0.5; // 0.5% / yr floor

// Bootstrap cap path: piecewise linear, lifted in Y3+.
// Month 0 (TGE) → 8%, month 24 → 4%, month 24+ → not binding (drawn dashed/grey to top).
function bootstrapCap(m: number): number {
  if (m <= 0) return 8;
  if (m >= 24) return 5; // after Y2 the 5% ceiling binds first; visually we tail to ceiling
  return 8 - (m / 24) * 4; // 8 → 4 linear
}

// Hand-picked rolling-180d-burn × elasticity values (% supply/yr).
// Plausible storyline:
//   Y1 ramp from cold start, hits cap-binding regime;
//   Y2 mid-cycle dip, then climb;
//   Y3 demand spikes against ceiling, then a trough toward floor.
const burnElasticity: { m: number; v: number }[] = [
  { m: 0, v: 0.3 },
  { m: 1, v: 0.6 },
  { m: 2, v: 1.4 },
  { m: 3, v: 2.5 },
  { m: 4, v: 3.6 },
  { m: 5, v: 5.0 },
  { m: 6, v: 6.4 }, // would exceed ceiling, clipped
  { m: 7, v: 7.2 },
  { m: 8, v: 6.1 },
  { m: 9, v: 4.8 },
  { m: 10, v: 3.9 },
  { m: 11, v: 3.2 },
  { m: 12, v: 3.7 },
  { m: 13, v: 4.5 },
  { m: 14, v: 5.3 },
  { m: 15, v: 5.8 },
  { m: 16, v: 5.1 },
  { m: 17, v: 4.4 },
  { m: 18, v: 3.6 },
  { m: 19, v: 3.0 },
  { m: 20, v: 3.4 },
  { m: 21, v: 4.1 },
  { m: 22, v: 4.7 },
  { m: 23, v: 5.0 },
  { m: 24, v: 5.4 }, // bootstrap cap relaxes here
  { m: 25, v: 6.0 }, // ceiling binds
  { m: 26, v: 6.5 },
  { m: 27, v: 5.9 },
  { m: 28, v: 4.3 },
  { m: 29, v: 2.4 },
  { m: 30, v: 1.1 }, // demand trough
  { m: 31, v: 0.6 },
  { m: 32, v: 0.4 }, // would dip below floor, clamped
  { m: 33, v: 0.8 },
  { m: 34, v: 1.9 },
  { m: 35, v: 3.2 },
  { m: 36, v: 4.0 },
];

// Actual mint rate = max(floor, min(ceiling, bootstrap_cap, burn×elasticity))
function mintAt(m: number, v: number): number {
  const cap = bootstrapCap(m);
  const upper = Math.min(CEIL, cap, v);
  return Math.max(FLOOR, upper);
}

const mintSeries = burnElasticity.map((p) => ({
  m: p.m,
  v: mintAt(p.m, p.v),
}));

// ----- helpers: build SVG path "d" string -----
function pathOf(
  pts: { m: number; v: number }[],
  closeToBaseline?: number,
): string {
  if (pts.length === 0) return "";
  const parts: string[] = [];
  for (let i = 0; i < pts.length; i++) {
    const x = xScale(pts[i].m).toFixed(2);
    const y = yScale(pts[i].v).toFixed(2);
    parts.push(`${i === 0 ? "M" : "L"} ${x} ${y}`);
  }
  if (typeof closeToBaseline === "number") {
    const xLast = xScale(pts[pts.length - 1].m).toFixed(2);
    const xFirst = xScale(pts[0].m).toFixed(2);
    const yBase = yScale(closeToBaseline).toFixed(2);
    parts.push(`L ${xLast} ${yBase}`);
    parts.push(`L ${xFirst} ${yBase}`);
    parts.push("Z");
  }
  return parts.join(" ");
}

// Bootstrap cap polyline (drawn 0..24 as solid, 24..36 as fading dashed)
const capSolidPts = [
  { m: 0, v: 8 },
  { m: 24, v: 4 },
];
const capFadePts = [
  { m: 24, v: 4 },
  { m: 36, v: 4 }, // visually carried as "not binding" with reduced opacity / dashed
];

// Y gridline values
const yTicks = [0, 1, 2, 3, 4, 5, 6, 7, 8];
// X gridline values (months) — annotate quarters
const xTicks = [0, 6, 12, 18, 24, 30, 36];
---

<figure
  class="surface-card-strong"
  aria-label="BME emission envelope: rolling-180d burn × elasticity, clipped above by 5% supply/year ceiling and the year-N bootstrap cap, clamped below by the 0.5% floor."
>
  <div class="flex items-baseline justify-between border-b border-crust-800 pb-3">
    <div>
      <p
        class="font-mono text-[10px] uppercase tracking-[0.22em] text-crust-500"
      >
        Mint envelope · pallet-bme
      </p>
      <h3 class="mt-1 text-lg font-semibold tracking-tight text-crust-100">
        Demand-elastic, with floor and ceiling
      </h3>
    </div>
    <p class="hidden font-mono text-[10px] uppercase tracking-[0.18em] text-crust-500 sm:block">
      synthetic envelope · illustrative
    </p>
  </div>

  <!-- the chart -->
  <div class="mt-4 overflow-x-auto">
    <svg
      viewBox={`0 0 ${W} ${H}`}
      class="block h-auto w-full min-w-[480px]"
      role="img"
      aria-hidden="true"
    >
      <defs>
        <!-- soft fill under the mint curve -->
        <linearGradient id="mint-fill" x1="0" x2="0" y1="0" y2="1">
          <stop offset="0%" stop-color="#f59e0b" stop-opacity="0.32" />
          <stop offset="100%" stop-color="#f59e0b" stop-opacity="0.02" />
        </linearGradient>
        <!-- clip to plot area -->
        <clipPath id="plot-clip">
          <rect x={PAD_L} y={PAD_T} width={plotW} height={plotH} />
        </clipPath>
      </defs>

      <!-- ── plot frame ───────────────────────────────── -->
      <rect
        x={PAD_L}
        y={PAD_T}
        width={plotW}
        height={plotH}
        fill="#0b0d10"
        stroke="#1a1f29"
        stroke-width="1"
      />

      <!-- horizontal gridlines -->
      <g stroke="#1a1f29" stroke-width="1">
        {
          yTicks.map((t) => (
            <line
              x1={PAD_L}
              x2={PAD_L + plotW}
              y1={yScale(t)}
              y2={yScale(t)}
            />
          ))
        }
      </g>

      <!-- vertical gridlines (quarter cadence) -->
      <g stroke="#11141a" stroke-width="1">
        {
          xTicks.map((t) => (
            <line
              x1={xScale(t)}
              x2={xScale(t)}
              y1={PAD_T}
              y2={PAD_T + plotH}
            />
          ))
        }
      </g>

      <!-- Y axis labels (% / yr) -->
      <g
        font-family="JetBrains Mono, ui-monospace, monospace"
        font-size="10"
        fill="#7c8597"
      >
        {
          yTicks.map((t) => (
            <text x={PAD_L - 8} y={yScale(t) + 3} text-anchor="end">
              {t}%
            </text>
          ))
        }
      </g>

      <!-- X axis labels (months 0..36) -->
      <g
        font-family="JetBrains Mono, ui-monospace, monospace"
        font-size="10"
        fill="#7c8597"
      >
        {
          xTicks.map((t) => (
            <text
              x={xScale(t)}
              y={PAD_T + plotH + 16}
              text-anchor="middle"
            >
              m{t}
            </text>
          ))
        }
      </g>

      <!-- Y-axis title (rotated) -->
      <text
        x={16}
        y={PAD_T + plotH / 2}
        transform={`rotate(-90 16 ${PAD_T + plotH / 2})`}
        text-anchor="middle"
        font-family="JetBrains Mono, ui-monospace, monospace"
        font-size="10"
        fill="#a5acbb"
        letter-spacing="0.12em"
      >
        MINT RATE · % SUPPLY / YR
      </text>

      <!-- X-axis title -->
      <text
        x={PAD_L + plotW / 2}
        y={H - 12}
        text-anchor="middle"
        font-family="JetBrains Mono, ui-monospace, monospace"
        font-size="10"
        fill="#a5acbb"
        letter-spacing="0.12em"
      >
        TIME · MONTHS FROM TGE
      </text>

      <!-- ── phase band shading (year regions) ─────────── -->
      <g opacity="0.35" clip-path="url(#plot-clip)">
        <rect
          x={xScale(0)}
          y={PAD_T}
          width={xScale(12) - xScale(0)}
          height={plotH}
          fill="#11141a"
        />
        <rect
          x={xScale(24)}
          y={PAD_T}
          width={xScale(36) - xScale(24)}
          height={plotH}
          fill="#11141a"
        />
      </g>
      <g
        font-family="JetBrains Mono, ui-monospace, monospace"
        font-size="9"
        fill="#4f5b6e"
        letter-spacing="0.12em"
      >
        <text x={xScale(6)} y={PAD_T + 14} text-anchor="middle">
          YEAR 1 · BOOTSTRAP
        </text>
        <text x={xScale(18)} y={PAD_T + 14} text-anchor="middle">
          YEAR 2 · TAPER
        </text>
        <text x={xScale(30)} y={PAD_T + 14} text-anchor="middle">
          YEAR 3+ · ENVELOPE
        </text>
      </g>

      <!-- ── ceiling 5% (dashed magma) ───────────────────── -->
      <line
        x1={PAD_L}
        x2={PAD_L + plotW}
        y1={yScale(CEIL)}
        y2={yScale(CEIL)}
        stroke="#f59e0b"
        stroke-width="1.5"
        stroke-dasharray="6 4"
      />
      <text
        x={PAD_L + plotW - 6}
        y={yScale(CEIL) - 5}
        text-anchor="end"
        font-family="JetBrains Mono, ui-monospace, monospace"
        font-size="10"
        fill="#fbbf24"
      >
        ceiling · 5.0% / yr
      </text>

      <!-- ── floor 0.5% (dashed crystal) ─────────────────── -->
      <line
        x1={PAD_L}
        x2={PAD_L + plotW}
        y1={yScale(FLOOR)}
        y2={yScale(FLOOR)}
        stroke="#34d399"
        stroke-width="1.5"
        stroke-dasharray="6 4"
      />
      <text
        x={PAD_L + plotW - 6}
        y={yScale(FLOOR) - 5}
        text-anchor="end"
        font-family="JetBrains Mono, ui-monospace, monospace"
        font-size="10"
        fill="#6ee7b7"
      >
        floor · 0.5% / yr
      </text>

      <!-- ── bootstrap cap (solid → fading) ────────────── -->
      <g clip-path="url(#plot-clip)">
        <path
          d={pathOf(capSolidPts)}
          fill="none"
          stroke="#cdd1da"
          stroke-width="1.5"
          stroke-dasharray="3 3"
        />
        <path
          d={pathOf(capFadePts)}
          fill="none"
          stroke="#36404f"
          stroke-width="1"
          stroke-dasharray="2 6"
        />
      </g>
      <text
        x={xScale(2)}
        y={yScale(8) - 6}
        font-family="JetBrains Mono, ui-monospace, monospace"
        font-size="10"
        fill="#cdd1da"
      >
        bootstrap cap · 8% → 4%
      </text>

      <!-- ── rolling-180d burn × elasticity (ghost line) ── -->
      <g clip-path="url(#plot-clip)">
        <path
          d={pathOf(burnElasticity)}
          fill="none"
          stroke="#7c8597"
          stroke-width="1"
          stroke-dasharray="2 3"
        />
      </g>

      <!-- ── actual mint rate (clamped, area + line) ───── -->
      <g clip-path="url(#plot-clip)">
        <path
          d={pathOf(mintSeries, 0)}
          fill="url(#mint-fill)"
          stroke="none"
        />
        <path
          d={pathOf(mintSeries)}
          fill="none"
          stroke="#f59e0b"
          stroke-width="2"
          stroke-linejoin="round"
        />
      </g>

      <!-- annotation: trough event (~m31) -->
      <g
        font-family="JetBrains Mono, ui-monospace, monospace"
        font-size="9"
        fill="#a5acbb"
      >
        <line
          x1={xScale(32)}
          y1={yScale(FLOOR) + 8}
          x2={xScale(32)}
          y2={yScale(FLOOR) + 22}
          stroke="#7c8597"
          stroke-width="0.6"
        />
        <text x={xScale(32)} y={yScale(FLOOR) + 33} text-anchor="middle">
          floor binds · trough resilience
        </text>
      </g>

      <!-- annotation: ceiling hit (~m7) -->
      <g
        font-family="JetBrains Mono, ui-monospace, monospace"
        font-size="9"
        fill="#a5acbb"
      >
        <circle cx={xScale(7)} cy={yScale(CEIL)} r="3" fill="#fbbf24" />
        <line
          x1={xScale(7)}
          y1={yScale(CEIL) - 4}
          x2={xScale(7)}
          y2={yScale(CEIL) - 18}
          stroke="#7c8597"
          stroke-width="0.6"
        />
        <text
          x={xScale(7) + 6}
          y={yScale(CEIL) - 22}
          text-anchor="start"
        >
          burn × elasticity exceeds bootstrap cap · clipped
        </text>
      </g>
    </svg>
  </div>

  <!-- legend -->
  <ul
    class="mt-4 grid grid-cols-2 gap-x-6 gap-y-2 font-mono text-[11px] text-crust-400 sm:grid-cols-4"
  >
    <li class="flex items-center gap-2">
      <svg viewBox="0 0 16 4" class="h-1 w-4" aria-hidden="true">
        <line x1="0" y1="2" x2="16" y2="2" stroke="#f59e0b" stroke-width="2" />
      </svg>
      mint rate (actual)
    </li>
    <li class="flex items-center gap-2">
      <svg viewBox="0 0 16 4" class="h-1 w-4" aria-hidden="true">
        <line
          x1="0"
          y1="2"
          x2="16"
          y2="2"
          stroke="#7c8597"
          stroke-width="1"
          stroke-dasharray="2 3"
        />
      </svg>
      burn × elasticity
    </li>
    <li class="flex items-center gap-2">
      <svg viewBox="0 0 16 4" class="h-1 w-4" aria-hidden="true">
        <line
          x1="0"
          y1="2"
          x2="16"
          y2="2"
          stroke="#f59e0b"
          stroke-width="1.5"
          stroke-dasharray="6 4"
        />
      </svg>
      5% ceiling
    </li>
    <li class="flex items-center gap-2">
      <svg viewBox="0 0 16 4" class="h-1 w-4" aria-hidden="true">
        <line
          x1="0"
          y1="2"
          x2="16"
          y2="2"
          stroke="#34d399"
          stroke-width="1.5"
          stroke-dasharray="6 4"
        />
      </svg>
      0.5% floor
    </li>
  </ul>

  <p
    class="mt-5 border-t border-crust-800 pt-4 text-xs leading-relaxed text-crust-500"
  >
    Per epoch (~72 minutes), mint =
    <code class="rounded bg-crust-800/80 px-1 py-0.5 text-magma-300">
      MAX(floor, MIN(ceiling, year_N_cap, rolling_180d_burn × elasticity))
    </code>.
    Bootstrap cap declines from 8%/yr at TGE to 4%/yr by month 24; after that
    the rolling-burn envelope governs, clamped by the 5% ceiling above and the
    0.5% floor below. The synthetic curve is shown for illustration; the rule
    itself is pallet-enforced, and the chain rejects any mint above the computed bound.
  </p>
</figure>
