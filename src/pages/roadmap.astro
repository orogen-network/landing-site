---
import Base from "../layouts/Base.astro";
import CtaButton from "../components/CtaButton.astro";
import RoadmapArc from "../components/RoadmapArc.astro";

interface Phase {
  quarter: string;
  status: "shipped" | "live" | "future";
  title: string;
  target: string;
  gate: string;
  kpis: string[];
}

const phases: Phase[] = [
  {
    quarter: "Shipped (W0)",
    status: "shipped",
    title: "Stealth dev",
    target:
      "Centralised inference stack stood up (vLLM V1 + LiteLLM gateway). Operator-partner integration path designed against H100/H200 CC mode. First end-to-end signed-receipt path through the gateway.",
    gate: "Stack feasibility validated: gate cleared.",
    kpis: [
      "Gateway routes OpenAI-compatible traffic end-to-end",
      "H100/H200 CC mode attested in operator-partner lab integration",
      "p99 latency < 800ms for 8K-prompt / 1K-output on Llama-3.1-70B in lab",
      "TEE attestation overhead < 5% in lab measurement",
    ],
  },
  {
    quarter: "Shipped (W1)",
    status: "shipped",
    title: "Permissioned operator partners",
    target:
      "Pallet suite (pallet-bme, pallet-model-registry, pallet-operator-stake, pallet-job-market, pallet-yuma-consensus, pallet-slashing) written and integrated. L1–L4 verification stack composed end-to-end against the operator-partner pool. AMD MI3xx integration started.",
    gate: "Verification-stack composition validated end-to-end: gate cleared.",
    kpis: [
      "Pallet suite v0.9 integrated against the chain-node fork",
      "Verification mismatch rate < 0.1% of sampled requests in pre-testnet runs",
      "Operator-partner pool wired against the L1–L4 stack",
      "Adapter publishing path running end-to-end against pallet-model-registry",
    ],
  },
  {
    quarter: "Live now (Forge)",
    status: "live",
    title: "Forge testnet",
    target:
      "Forge public testnet is live. Seed validator node up; chain-indexer + GraphQL up; OpenAI-compatible traffic path to attested operators in active integration. Target second-vendor profile: AMD MI3xx and Blackwell B200 CC operators alongside H100/H200. Pallet suite covers pallet-bme, pallet-model-registry, pallet-operator-stake, pallet-job-market, pallet-yuma-consensus, pallet-slashing (pre-audit).",
    gate: "Second-vendor (AMD) operators reaching production-grade keeps the mainnet TGE schedule intact. Slippage here moves mainnet TGE forward in time.",
    kpis: [
      "15+ operators across NVIDIA + AMD on testnet",
      "Verification mismatch rate < 0.05% over sampled traffic",
      "p99 latency < 500ms on testnet routes",
      "100+ adapters published via pallet-model-registry",
      "Day-N replay coverage ≥ target sample-rate floor",
    ],
  },
  {
    quarter: "In progress (audit)",
    status: "live",
    title: "Multi-firm chain audit",
    target:
      "Three independent firms reviewing the chain pallets, the gateway burn path, and the slashing schedule in parallel. Slashing pallet stress test under way; CRL drill executed on Forge.",
    gate: "Mainnet TGE is conditional on the audit closing clean. Findings reset the clock; the audit gate moves the launch, not the messaging.",
    kpis: [
      "Three independent audit reports filed",
      "All critical and high findings resolved on Forge",
      "Slashing pallet stress test passing under adversarial conditions",
      "CRL drill rehearsed end-to-end on Forge",
    ],
  },
  {
    quarter: "After audit",
    status: "future",
    title: "Mainnet TGE",
    target:
      "Token live on Substrate fork mainnet. BME loop active from Day 1 — real burn, real mint, every customer transaction. All Forge operators and customers migrate to on-chain mainnet settlement. EVM JSON-RPC layer live; ETH bridge live.",
    gate: "If Day-30 burn < 0.3× mint, the BME loop is not capturing customer demand. Pause permissionless onboarding; investigate gateway-burn integrity.",
    kpis: [
      "TGE clean (no chain halts in first 30 days)",
      "Day-30 cumulative burn > 0.5× Day-30 cumulative mint",
      "Token listing on ≥ 2 mid-tier CEXes within 30 days",
      "Day-90 subsidy ratio < 2×",
      "Operator count growing (permissioned-only is acceptable)",
    ],
  },
  {
    quarter: "Post-TGE",
    status: "future",
    title: "Permissionless onboarding · LoRA marketplace · opML layer",
    target:
      "Permissionless operator onboarding. Permissionless adapter publishing. opML challenge window deployed (Layer 5). Cross-region routing matures. Permissionless validator entry; Yuma slashing live.",
    gate: "If verification mismatch rate climbs above 0.1% after permissionless opening, tighten operator registration requirements (raise stake floor at prosumer/edge).",
    kpis: [
      "30+ operators (permissionless)",
      "200+ adapters in catalog",
      "50+ customers paying",
      "$200K MRR",
      "p99 latency < 400ms",
      "Verification mismatch rate < 0.02%",
      "Yuma consensus running with ≥ 64 validators",
    ],
  },
  {
    quarter: "Post-TGE +2 quarters",
    status: "future",
    title: "Mobile inference · bridge launch · RL preparation",
    target:
      "Mobile-tier inference (Apple-silicon edge tier) productionised behind opt-in zkML for embeddings and classification. ETH ↔ Orogen bridge expanded with Snowbridge or equivalent. RL marketplace specification frozen (Phase 2 of training roadmap). Atropos task definitions accepted on testnet.",
    gate: "If no measurable RL customer demand by gate-review, postpone Phase 3 (federated post-training) and double-down on inference + LoRA.",
    kpis: [
      "$400K MRR (inference + LoRA + RL pilots)",
      "≥ 1 customer-paid RL training run completed on testnet",
      "Operator count > 50",
      "Subsidy ratio < 1.5×",
    ],
  },
  {
    quarter: "Post-TGE +4 quarters",
    status: "future",
    title: "RL pilots at scale",
    target:
      "Multiple concurrent INTELLECT-2-pattern RL runs (32B-class with math/code rewards). TOPLOC-style activation attestation for rollouts integrated. First externally-customer-paid post-training run.",
    gate: "Phase 3 (federated post-training) enters production only if sustained $200K+ MRR is attributable to training at this gate.",
    kpis: [
      "$700K+ MRR",
      "Operator count > 70",
      "Subsidy ratio < 1.2×",
      "First decentralised post-training cohort (7B-class) bolt-on operational",
    ],
  },
  {
    quarter: "Post-TGE +6 quarters",
    status: "future",
    title: "Federated post-training",
    target:
      "DisTrO / SparseLoCo bolt-on for 7B-class decentralised post-training in production. $1M/mo MRR. Decision: enter Phase 4 (pretraining-from-scratch market)?",
    gate: "Phase 4 entry is conditional on (a) sustained $12M+ annualised revenue and (b) subsidy ratio < 1×.",
    kpis: [
      "$12M+ annualised revenue",
      "100+ operators",
      "Subsidy ratio < 1×",
      "Phase 4 go/no-go decision rendered",
    ],
  },
];

const statusBadge: Record<Phase["status"], string> = {
  shipped: "border-magma-500/60 bg-magma-500/15 text-magma-300",
  live: "border-crystal-500/60 bg-crystal-500/15 text-crystal-400",
  future: "border-crust-600 bg-crust-800/70 text-crust-300",
};

const statusLabel: Record<Phase["status"], string> = {
  shipped: "SHIPPED",
  live: "LIVE NOW",
  future: "FUTURE",
};
---

<Base
  title="Roadmap"
  description="Forge testnet is live now, routing OpenAI-compatible traffic to attested operators. The W0 and W1 build waves are shipped. The audit gate is in progress. Mainnet TGE, the ETH bridge, permissionless onboarding, RL at scale, and federated post-training follow."
  path="/roadmap"
>
  <section class="container-page py-16">
    <p class="heading-eyebrow">Roadmap</p>
    <h1 class="mt-2 text-4xl font-semibold tracking-tight sm:text-5xl">
      Shipped, live, future. Nine phases. Nine decision gates.
    </h1>
    <p class="mt-4 max-w-3xl text-crust-300">
      The W0 and W1 build waves are shipped. The Forge testnet is live now —
      routing OpenAI-compatible traffic to attested operators, with validators
      replaying samples and operators earning testnet OROG. The multi-firm
      audit is in progress; mainnet TGE follows it. The remaining arc —
      permissionless onboarding, the ETH bridge, mobile inference, federated
      post-training — is future, each phase gated on real KPIs from the
      previous one. Gates are real: missing one moves the next phase, not the
      messaging.
    </p>
  </section>

  <section class="container-page pb-8">
    <RoadmapArc />
  </section>

  <section class="container-page pb-16">
    <p class="heading-eyebrow">Phase detail</p>
    <h2 class="mt-2 text-2xl font-semibold tracking-tight">Targets, gates, KPIs.</h2>
    <p class="mt-3 max-w-3xl text-crust-300">
      The first four phases map to the visual arc above (two shipped, Forge
      live, audit in progress). The remaining five are sequenced after
      mainnet TGE: permissionless onboarding, mobile + bridge, RL pilots,
      federated post-training, and the Phase 4 pretraining-from-scratch
      go/no-go.
    </p>

    <ol class="mt-8 space-y-6">
      {
        phases.map((p, idx) => (
          <li class="surface-card-strong">
            <div class="flex flex-wrap items-baseline gap-3">
              <span class={`rounded-md border px-2 py-0.5 font-mono text-[10px] uppercase tracking-[0.14em] ${statusBadge[p.status]}`}>
                {statusLabel[p.status]}
              </span>
              <span class="rounded-md border border-magma-500/60 bg-magma-500/10 px-2 py-0.5 font-mono text-xs text-magma-300">
                {p.quarter}
              </span>
              <span class="font-mono text-xs text-crust-500">Phase {idx + 1} / {phases.length}</span>
              <h2 class="text-xl font-semibold text-crust-100">{p.title}</h2>
            </div>

            <div class="mt-4 grid gap-4 lg:grid-cols-[1fr_1fr_1fr]">
              <div>
                <div class="text-xs font-medium uppercase tracking-wider text-crust-500">Target</div>
                <p class="mt-1.5 text-sm leading-relaxed text-crust-200">{p.target}</p>
              </div>
              <div>
                <div class="text-xs font-medium uppercase tracking-wider text-crust-500">Gate criterion</div>
                <p class="mt-1.5 text-sm leading-relaxed text-crust-200">{p.gate}</p>
              </div>
              <div>
                <div class="text-xs font-medium uppercase tracking-wider text-crust-500">KPIs</div>
                <ul class="mt-1.5 list-disc space-y-1 pl-5 text-sm leading-relaxed text-crust-200">
                  {p.kpis.map((k) => <li>{k}</li>)}
                </ul>
              </div>
            </div>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="border-t border-crust-800/80 bg-crust-900/40 py-16">
    <div class="container-page">
      <p class="heading-eyebrow">Cross-phase invariants</p>
      <h2 class="mt-2 text-3xl font-semibold tracking-tight">What does not move.</h2>
      <ul class="mt-6 max-w-3xl list-disc space-y-2 pl-6 text-crust-200">
        <li>The BME loop runs unbroken from TGE Day 1; there is no "pay USDC and skip the token" backdoor at any phase.</li>
        <li>The verification stack is L1–L8 throughout; new layers may be added (e.g. ZKML for embeddings), but no layer is dropped.</li>
        <li>The 75 / 15 / 5 / 5 reward split is at-launch governance-adjustable but constitutionally bounded — provider share cannot fall below 60%.</li>
        <li>The 5% supply/year mint ceiling is hard. The chain rejects mints above it. Governance can lower it; raising it requires constitutional amendment (supermajority, 60-day timelock).</li>
        <li>Multi-vendor TEE at launch. Single-vendor monoculture is treated as a security regression and reverts to permissioned-only operator onboarding until restored.</li>
      </ul>

      <div class="mt-10 flex flex-wrap gap-3">
        <CtaButton href="/tokenomics" variant="primary">Tokenomics detail</CtaButton>
        <CtaButton href="/how-it-works" variant="secondary">Verification stack</CtaButton>
        <CtaButton href="/faq" variant="ghost">FAQ</CtaButton>
      </div>
    </div>
  </section>
</Base>
