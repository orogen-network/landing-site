---
import Base from "../layouts/Base.astro";
import CtaButton from "../components/CtaButton.astro";
import BmeFlowOracle from "../components/BmeFlowOracle.astro";

const layers = [
  {
    n: "L1",
    title: "Stake + identity",
    body: "Operator registers a coldkey + hotkey + GPU device cert hash + TEE attestation report. Stake is tier-dependent (500 OROG dc-premium → 0 edge/embed). Two coldkeys claiming the same GPU device cert are both slashed. Heartbeats every ~5 blocks (1 minute) gate routing eligibility.",
  },
  {
    n: "L2",
    title: "TEE attestation",
    body: "NVIDIA NVTrust (H100/H200/B200 confidential compute mode) + Intel TDX or AMD SEV-SNP on the host. The chain verifies the attestation chain end-to-end (NVTrust + Intel TA / AMD KDS). Re-attestation required every 7 days, or on firmware update. Multi-vendor at launch — no single-vendor monoculture.",
  },
  {
    n: "L3",
    title: "Deterministic kernels",
    body: "Workers replace stock FP8 GEMM with deterministic kernels (SGLang determinism mode or Thinking Machines batch-invariant kernels). Mandatory for dc-premium, dc-standard, cloud-rented, prosumer. Determinism is the precondition for replay sampling: bit-identical re-execution must be possible on a validator.",
  },
  {
    n: "L4",
    title: "Validator replay sampling",
    body: "Validators sample 1–5% of finalised jobs and replay them on identical hardware. Output mismatch → challenge. This is Yuma-style consensus over real work, not vibes. Validators have 10× operator min stake and are themselves attested. See RFC-0006.",
  },
  {
    n: "L5",
    title: "opML challenge window",
    body: "Disputed jobs enter a 24h challenge window. Watchers re-execute and post commitments; a bisection game narrows the divergent layer; the chain dispute panel renders a slashing decision. Foundation hosts the first watcher set; permissionless watchers open in Q3 2027.",
  },
  {
    n: "L6",
    title: "zkML option (where economical)",
    body: "Selected small-model / embedding workloads support full zkML proofs (zkSNARK or zkSTARK over the network compute). Proving cost is currently 100–10000× inference cost — viable only for very high-stakes per-query workloads. The protocol charges this as a premium tier.",
  },
  {
    n: "L7",
    title: "Adapter + base-model commitment",
    body: "All weights are content-addressed (Merkle root over tensor files, on-chain pin via pallet-model-registry). The CDN serves bits; operators verify-on-load. Customers can audit the exact (base_model, adapter) the operator ran via the receipt and the public root hash.",
  },
  {
    n: "L8",
    title: "Receipt + customer audit",
    body: "Every response carries (model_hash, adapter_hash, prompt_hash, output_hash, operator_hotkey, attestation_quote, timestamp), signed by the operator. Customer SDKs verify the signature locally; the chain stores the receipt commitment for arbitration. The customer never has to trust us; the chain receipt is the source of truth.",
  },
];

const bmeSteps = [
  { i: 1, label: "Customer tops up gateway in USDC/USD/ETH/BTC. Payment recorded, oracle-quoted at top-up time." },
  { i: 2, label: "Gateway burns OROG at oracle spot. OROG bought from the protocol-managed AMM or the open market; the smart contract enforces the burn." },
  { i: 3, label: "CUC compute credit minted (USD-pegged, non-transferable, 30-day expiry). credit_id mapped to customer account; routable per job." },
  { i: 4, label: "Customer submits job (single inference / batch / fine-tune / RL rollout). Job assigns CUC to consume on completion." },
  { i: 5, label: "Network router selects operator by tier + region + KV-warmness. Operator runs inference under the verification stack; signed receipt returned." },
  { i: 6, label: "Job completes; validator sampling confirms (L4). CUC is consumed (burned). pallet-bme.on_job_finalised fires." },
  { i: 7, label: "Fresh OROG minted to operator at oracle spot. Split: 75% provider / 15% verification / 5% treasury / 5% governance." },
  { i: 8, label: "Operator auto-swaps configurable fraction to USDC at protocol-managed AMM (default 70%). Net result: operator paid in USD-equivalent units mechanically." },
];
---

<Base
  title="How it works"
  description="The Orogen verification stack: 8 layers from stake-and-identity through TEE attestation, deterministic kernels, validator replay sampling, opML challenge windows, and signed customer receipts."
  path="/how-it-works"
>
  <section class="container-page py-16">
    <p class="heading-eyebrow">Protocol architecture</p>
    <h1 class="mt-2 text-4xl font-semibold tracking-tight sm:text-5xl">How Orogen works</h1>
    <p class="mt-4 max-w-3xl text-crust-300">
      Orogen is a Substrate-based L1 with eight verification layers stacked on
      top of an OpenAI-compatible gateway. The chain owns model and operator
      registration, job settlement, validator consensus, and the burn-and-mint
      engine. The workers run open-source inference servers (vLLM V1, SGLang,
      TRT-LLM, llama.cpp) with three additions: TEE attestation, deterministic
      kernels, and a signed-receipt sidecar.
    </p>
  </section>

  <section class="border-y border-crust-800/80 bg-crust-900/40 py-16">
    <div class="container-page">
      <p class="heading-eyebrow">The verification stack</p>
      <h2 class="mt-2 text-3xl font-semibold tracking-tight">Eight layers, no single point of trust.</h2>
      <p class="mt-3 max-w-3xl text-crust-300">
        No one layer is sufficient. Stake-only ("trust the operator's collateral")
        is the weakest of the eight; zkML ("prove every token") is the strongest
        but costs 100–10000× inference. We compose them so the verification cost
        is proportional to the value-at-risk per request.
      </p>

      <ol class="mt-10 grid gap-5 lg:grid-cols-2">
        {
          layers.map((l) => (
            <li class="surface-card">
              <div class="flex items-center gap-3">
                <span class="rounded-md border border-magma-500/60 bg-magma-500/10 px-2 py-0.5 font-mono text-xs text-magma-300">
                  {l.n}
                </span>
                <h3 class="text-lg font-semibold text-crust-100">{l.title}</h3>
              </div>
              <p class="mt-3 text-sm leading-relaxed text-crust-300">{l.body}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section class="container-page py-16">
    <p class="heading-eyebrow">The BME loop</p>
    <h2 class="mt-2 text-3xl font-semibold tracking-tight">Burn-and-mint, with USD payouts on the rails.</h2>
    <p class="mt-3 max-w-3xl text-crust-300">
      Every customer transaction routes through the burn-and-mint engine.
      Steps 2 (burn) and 7 (mint) are at <em>different</em> oracle prices: if
      OROG appreciates between top-up and consumption, net burn occurs and
      supply is permanently reduced (Akash post-BME pattern). If OROG
      depreciates, the protocol mints enough to honor the customer's USD-quoted
      payment — symmetric, bounded by emission policy.
    </p>

    <ol class="mt-8 space-y-3">
      {
        bmeSteps.map((s) => (
          <li class="flex gap-4 rounded-md border border-crust-800 bg-crust-900/50 px-4 py-3">
            <span class="mt-0.5 inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-magma-500/60 bg-magma-500/10 font-mono text-xs text-magma-300">
              {s.i}
            </span>
            <p class="text-sm leading-relaxed text-crust-200">{s.label}</p>
          </li>
        ))
      }
    </ol>

    <div class="mt-8">
      <BmeFlowOracle />
    </div>
  </section>

  <section class="border-t border-crust-800/80 bg-crust-900/40 py-16">
    <div class="container-page">
      <p class="heading-eyebrow">Deterministic kernels</p>
      <h2 class="mt-2 text-3xl font-semibold tracking-tight">Why determinism is the precondition.</h2>
      <p class="mt-3 max-w-3xl text-crust-300">
        Replay sampling (L4) only works if a validator can reproduce the
        operator's output bit-for-bit. Stock FP8 GEMM on H100/H200 is
        non-deterministic across batch sizes and SM count — a validator with the
        same model and same prompt can produce slightly different logits. That
        breaks the verification.
      </p>
      <p class="mt-4 max-w-3xl text-crust-300">
        Orogen workers ship with deterministic kernel modes (SGLang determinism
        mode or Thinking Machines batch-invariant kernels) for dc-premium,
        dc-standard, cloud-rented, and prosumer tiers. The kernel fixes the
        reduction order and the tile scheduler. Throughput cost: ~3–8% versus
        stock FP8 on H100 (measured on Llama-3.1-70B; full numbers in the docs).
      </p>
      <p class="mt-4 max-w-3xl text-crust-300">
        Edge and embed-only tiers run on Apple Silicon and CPU where
        deterministic kernels are not practical. Those tiers use stake-only
        verification — the customer accepts a weaker verification posture for
        cheaper pricing.
      </p>
    </div>
  </section>

  <section class="container-page py-16">
    <p class="heading-eyebrow">Attestation flow</p>
    <h2 class="mt-2 text-3xl font-semibold tracking-tight">From boot to receipt.</h2>

    <ol class="mt-6 space-y-3 text-crust-200">
      <li class="rounded-md border border-crust-800 bg-crust-900/50 px-4 py-3">
        <strong class="text-crust-100">Boot.</strong> Worker boots into Confidential Compute mode (H100/H200 CC + TDX/SEV-SNP host). GPU and host produce attestation quotes.
      </li>
      <li class="rounded-md border border-crust-800 bg-crust-900/50 px-4 py-3">
        <strong class="text-crust-100">Register.</strong> Worker submits quotes to the chain via pallet-operator-stake. The pallet verifies the chain (NVTrust roots + Intel TA / AMD KDS) and binds (coldkey, hotkey, GPU device cert).
      </li>
      <li class="rounded-md border border-crust-800 bg-crust-900/50 px-4 py-3">
        <strong class="text-crust-100">Heartbeat.</strong> Every ~5 blocks (1 minute), worker posts (attestation_freshness, hashrate, available_capacity). Missed heartbeats decay reputation.
      </li>
      <li class="rounded-md border border-crust-800 bg-crust-900/50 px-4 py-3">
        <strong class="text-crust-100">Serve.</strong> Each inference produces a receipt bound to the attestation quote and the per-job nonce. The receipt is signed by the operator hotkey and returned with the response.
      </li>
      <li class="rounded-md border border-crust-800 bg-crust-900/50 px-4 py-3">
        <strong class="text-crust-100">Sample.</strong> Validators pull a 1–5% sample of finalised receipts and replay on attested hardware. Mismatches trigger the L5 challenge.
      </li>
      <li class="rounded-md border border-crust-800 bg-crust-900/50 px-4 py-3">
        <strong class="text-crust-100">Re-attest.</strong> Every 7 days, or on firmware/driver update. Stale attestations route to zero traffic until refreshed.
      </li>
    </ol>

    <div class="mt-10 flex flex-wrap gap-3">
      <CtaButton href="https://docs.orogen.network" variant="primary" rel="noopener noreferrer">Read the RFCs</CtaButton>
      <CtaButton href="/validators" variant="secondary">Validator deep-dive</CtaButton>
      <CtaButton href="/operators" variant="ghost">Operator deep-dive</CtaButton>
    </div>
  </section>
</Base>
